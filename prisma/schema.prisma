generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum IncidentStatus {
  PENDING
  ANALYZING
  COMPLETED
  FAILED
  ARCHIVED
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ChatRole {
  USER
  ASSISTANT
}


model User {
  id         String   @id @default(cuid())
  googleId   String   @unique
  name       String
  email      String   @unique
  avatar     String?

  incidents  Incident[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Incident {
  id              String          @id @default(cuid())

  title           String

  status          IncidentStatus  @default(PENDING)

  summary         String?

  severity        Severity?

  affectedService String?

  rootCause       String?

  confidence      Float?

  timeline        Json?

  evidence        Json?

  recommendations Json?

  prevention      Json?

  analyzedAt      DateTime?

  analysisStartedAt DateTime?
  analysisDurationMs Int?

  errorMessage    String?

  userId          String

  isDeleted       Boolean  @default(false)
  deletedAt       DateTime?

  category         String?
  affectedServices Json?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User @relation(fields: [userId], references: [id])

  files           UploadedFile[]
  aiResponses     AIResponse[]
  chatMessages    ChatMessage[]


  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([isDeleted])
}

model ChatMessage {
  id         String   @id @default(cuid())

  incidentId String
  role       ChatRole
  message    String

  createdAt  DateTime @default(now())

  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  @@index([incidentId, createdAt])
}

model UploadedFile {
  id            String   @id @default(cuid())

  filename      String
  originalName  String
  extension     String
  mimeType      String
  size          Int
  path          String

  checksum      String @unique

  incidentId    String
  incident      Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([incidentId])
}

model AIResponse {
  id           String   @id @default(cuid())

  prompt       String

  response     Json

  modelVersion String?

  incidentId   String   @unique

  incident     Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)

  createdAt    DateTime @default(now())
}

