# ==========================================
# OpsPilot-AI - Environment Configuration
# ==========================================
# Copy this file to .env and fill in actual values
# DO NOT commit .env file with real credentials
#
# Generate JWT secrets:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# ============ Server Configuration ============
PORT=8000
NODE_ENV=development
LOG_LEVEL=info

# ============ Database Configuration ============
# Format: postgres://username:password@host:port/database_name
DATABASE_URL=postgres://admin:yourpassword@localhost:5433/OpsPilot

# ============ Redis Configuration ============
# Format: redis://:password@host:port
REDIS_URL=redis://:yourpassword@localhost:6379

# ============ CORS Configuration ============
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:4000,http://localhost:4001,http://localhost:4005

# ============ JWT Configuration ============
# JWT Access Token Secret (generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_ACCESS_SECRET=your_64_character_hex_string_here # example: "0f8bf908f8d38527c188c93bda49d48bd421a43fa0bdf3e77de1f0db785e6f37"

# JWT Refresh Token Secret (generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_REFRESH_SECRET=your_128_character_hex_string_here # example: "826d2c0edb5ad8f8ac7668556c034ea228931a49576aefccc80d6f469cc4a34c4da82ca43a5c43de91ffdad2f4644c655e2eb3ccbb8bc2848cb64fe7ea2a1ab9"

# Token expiration times
ACCESS_TOKEN_EXP=15m
REFRESH_TOKEN_EXP=7d

# Token expiration in seconds (for Redis TTL)
ACCESS_TOKEN_EXP_SEC=900
REFRESH_TOKEN_EXP_SEC=604800

# Redis user session TTL in seconds (86400 = 24 hours)
REDIS_USER_TTL=86400

# ============ Google Authentication (required) ============
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ============ OpenAI Configuration (required) ============
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_LOG_CHARS=100000

# ============ Uploads ============
# Max upload size in bytes (default 5MB)
MAX_UPLOAD_SIZE=5242880

# ============ Cloudinary (required) ============
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=opspilot/incidents
